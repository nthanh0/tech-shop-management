@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h1 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Sản phẩm</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Bảng điều khiển</a></li>
    <li class="breadcrumb-item active">Quản lý Sản phẩm</li>
</ol>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0" style="color: #1b45cf; font-weight: 600;">
            <i class="fas fa-table me-1"></i> Dữ liệu Hàng hóa
        </h5>
        <button class="btn text-white" style="background-color: #1b45cf;">
            <i class="fas fa-plus me-1"></i> Thêm sản phẩm
        </button>
    </div>
    <div class="card-body">
        
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                        <th class="text-center" width="5%">STT</th>
                        <th width="15%">Mã SP</th>
                        <th width="30%">Tên sản phẩm</th>
                        <th width="15%">Thương hiệu</th>
                        <th class="text-center" width="15%">Trạng thái</th>
                        <th class="text-center" width="20%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center">1</td>
                        <td><strong>PROD01</strong></td>
                        <td>iPhone 15 Pro Max</td>
                        <td>Apple</td>
                        <td class="text-center">
                            <span class="badge bg-success rounded-pill px-3">Đang bán</span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" title="Xóa">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                    
                    <tr>
                        <td class="text-center">2</td>
                        <td><strong>PROD02</strong></td>
                        <td>Samsung Galaxy S24 Ultra</td>
                        <td>Samsung</td>
                        <td class="text-center">
                            <span class="badge bg-success rounded-pill px-3">Đang bán</span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" title="Xóa">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-center">3</td>
                        <td><strong>PROD03</strong></td>
                        <td>MacBook Pro 14 inch M3</td>
                        <td>Apple</td>
                        <td class="text-center">
                            <span class="badge bg-secondary rounded-pill px-3">Hết hàng</span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" title="Xóa">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <nav aria-label="Page navigation" class="mt-3">
            <ul class="pagination justify-content-end mb-0">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Trước</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#" style="background-color: #1b45cf; border-color: #1b45cf;">1</a></li>
                <li class="page-item"><a class="page-link" href="#" style="color: #1b45cf;">2</a></li>
                <li class="page-item"><a class="page-link" href="#" style="color: #1b45cf;">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#" style="color: #1b45cf;">Sau</a>
                </li>
            </ul>
        </nav>

    </div>
</div>