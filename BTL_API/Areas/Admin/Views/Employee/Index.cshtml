@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Nhân viên</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Nhân sự & Đối tác</a></li>
    <li class="breadcrumb-item active">Nhân viên</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-filter"></i></span>
            <select class="form-select border-start-0" aria-label="Filter Role">
                <option selected>Tất cả bộ phận...</option>
                <option value="Quản lý">Quản lý</option>
                <option value="Bán hàng">Bán hàng</option>
                <option value="Thủ kho">Thủ kho</option>
                <option value="Thu ngân">Thu ngân</option>
                <option value="Kỹ thuật">Kỹ thuật</option>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm tên, SĐT..." aria-label="Search">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn btn-secondary text-white" title="Xuất danh sách Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-export"></i> Xuất file
        </button>
        
        <button class="btn text-white" title="Thêm nhân viên" style="background-color: #1b45cf; border: none;">
            <i class="fas fa-user-plus fa-lg me-1"></i> Thêm mới
        </button>
    </div>
</div>

