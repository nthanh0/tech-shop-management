@{
    ViewData["Title"] = "Báo cáo Doanh thu";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Báo Cáo Tổng Quan</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Cửa hàng</a></li>
    <li class="breadcrumb-item active">Thống kê</li>
</ol>

<div class="row mb-4">
    <div class="col-xl-4 col-md-6">
        <div class="card bg-primary text-white mb-4 shadow border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-white-50">Tổng Doanh Thu (Hoàn thành)</div>
                        <h2 class="fw-bold mb-0" id="totalRevenue">Đang tải...</h2>
                    </div>
                    <i class="fas fa-chart-line fa-3x text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-7">
        <div class="card mb-4 shadow border-0">
            <div class="card-header bg-white fw-bold" style="color: #0a2551;">
                <i class="fas fa-box-open me-1 text-primary"></i> Top 10 Sản Phẩm Bán Chạy Nhất
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Top</th>
                                <th>Tên sản phẩm</th>
                                <th>Màu sắc</th>
                                <th class="text-center pe-3">Đã bán</th>
                            </tr>
                        </thead>
                        <tbody id="topProductsTable">
                            <tr><td colspan="4" class="text-center text-muted">Đang tải dữ liệu...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card mb-4 shadow border-0">
            <div class="card-header bg-white fw-bold" style="color: #0a2551;">
                <i class="fas fa-crown me-1 text-warning"></i> Top 3 Khách Hàng VIP
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Hạng</th>
                                <th>Khách hàng</th>
                                <th class="text-end pe-3">Tổng chi tiêu</th>
                            </tr>
                        </thead>
                        <tbody id="topCustomersTable">
                            <tr><td colspan="3" class="text-center text-muted">Đang tải dữ liệu...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Admin-report.js" asp-append-version="true"></script>
}