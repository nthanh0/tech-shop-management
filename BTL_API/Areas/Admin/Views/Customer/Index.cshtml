@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Khách hàng</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Nhân sự & Đối tác</a></li>
    <li class="breadcrumb-item active">Khách hàng</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-map-marker-alt"></i></span>
            <select class="form-select border-start-0" id="filterArea" onchange="executeCusSearch()">
                <option value="All" selected>Tất cả khu vực...</option>
                <optgroup label="Miền Bắc">
                    <option value="Hà Nội">Hà Nội</option>
                    <option value="Thái Bình">Thái Bình</option>
                    <option value="Hải Phòng">Hải Phòng</option>
                    <option value="Quảng Ninh">Quảng Ninh</option>
                    <option value="Bắc Ninh">Bắc Ninh</option>
                    <option value="Hải Dương">Hải Dương</option>
                    <option value="Nam Định">Nam Định</option>
                    <option value="Hà Nam">Hà Nam</option>
                </optgroup>
                <optgroup label="Miền Trung">
                    <option value="Đà Nẵng">Đà Nẵng</option>
                    <option value="Thanh Hóa">Thanh Hóa</option>
                    <option value="Nghệ An">Nghệ An</option>
                    <option value="Huế">Thừa Thiên Huế</option>
                    <option value="Quảng Nam">Quảng Nam</option>
                    <option value="Khánh Hòa">Khánh Hòa</option>
                    <option value="Lâm Đồng">Lâm Đồng</option>
                    <option value="Bình Thuận">Bình Thuận</option>
                </optgroup>
                <optgroup label="Miền Nam">
                    <option value="Hồ Chí Minh">TP. Hồ Chí Minh</option>
                    <option value="Bình Dương">Bình Dương</option>
                    <option value="Đồng Nai">Đồng Nai</option>
                    <option value="Cần Thơ">Cần Thơ</option>
                    <option value="Long An">Long An</option>
                    <option value="Tiền Giang">Tiền Giang</option>
                    <option value="An Giang">An Giang</option>
                    <option value="Kiên Giang">Kiên Giang</option>
                </optgroup>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm tên, SĐT, Email..." aria-label="Search" id="cusSearchInput" onkeyup="executeCusSearch()">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button" onclick="executeCusSearch()">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn btn-secondary text-white" title="Gửi Email hàng loạt" style="background-color: #6c757d; border: none;">
            <i class="fas fa-envelope"></i> Gửi Mail
        </button>
        <button class="btn btn-secondary text-white" title="Xuất danh sách Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-export"></i> Xuất file
        </button>
        
        <button class="btn text-white" title="Thêm khách hàng" data-bs-toggle="modal"
                data-bs-target="#addCustomerModal" style="background-color: #1b45cf; border: none;">
            <i class="fas fa-plus-circle fa-lg me-1"></i> Thêm mới
        </button>
    </div>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                        <th class="ps-3" width="5%"><input type="checkbox" class="form-check-input"></th>
                        <th width="10%">Mã KH</th>
                        <th width="20%">Khách hàng</th>
                        <th width="15%">Số điện thoại</th>
                        <th width="20%">Email</th>
                        <th width="15%">Địa chỉ</th>
                        <th class="text-center pe-3" width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody id="cusTableBody">
                   
                    
                 
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="card-footer bg-white py-3">
        <ul class="pagination justify-content-end mb-0">
        </ul>
    </div>
</div>
@await Html.PartialAsync("_AddCusModal")
@await Html.PartialAsync("_EditCusModal")
@section Scripts {
    <script src="~/js/Admin-cus.js" asp-append-version="true"></script>
}