                        <th class="ps-3" width="5%"><input type="checkbox" class="form-check-input"></th>
                        <th width="10%">Mã KH</th>
                        <th width="20%">Khách hàng</th>
                        <th width="15%">Số điện thoại</th>
                        <th width="20%">Email</th>
                        <th width="15%">Địa chỉ</th>
                        <th class="text-center pe-3" width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-3"><input type="checkbox" class="form-check-input"></td>
                        <td><strong>CUS01</strong></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 35px; height: 35px; font-weight: bold;">V</div>
                                Vũ Đại Dương
                            </div>
                        </td>
