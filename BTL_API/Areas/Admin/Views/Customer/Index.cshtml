                            <button class="btn btn-sm btn-light text-success" title="Lịch sử mua hàng"><i class="fas fa-shopping-bag"></i></button>
                            <button class="btn btn-sm btn-light text-primary" title="Sửa"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light text-danger" title="Xóa/Khóa"><i class="fas fa-ban"></i></button>
                        </td>
                    </tr>

                    <tr>
                        <td class="ps-3"><input type="checkbox" class="form-check-input"></td>
