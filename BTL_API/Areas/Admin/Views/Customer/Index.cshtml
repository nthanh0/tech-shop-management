                        <td>Đống Đa, Hà Nội</td>
                        <td class="text-center pe-3">
                            <button class="btn btn-sm btn-light text-success" title="Lịch sử mua hàng"><i class="fas fa-shopping-bag"></i></button>
                            <button class="btn btn-sm btn-light text-primary" title="Sửa"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light text-danger" title="Xóa/Khóa"><i class="fas fa-ban"></i></button>
                        </td>
                    </tr>
                    
                    <tr>
                        <td class="ps-3"><input type="checkbox" class="form-check-input"></td>
                        <td><strong>CUS02</strong></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-info text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 35px; height: 35px; font-weight: bold;">Đ</div>
                                Đặng Mai Linh
                            </div>
                        </td>
                        <td>0977222333</td>
                        <td>linhdang@gmail.com</td>
                        <td>Hai Bà Trưng, HN</td>
