@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body style="background-color: #f4f6f9;">

    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card shadow-sm" style="width: 400px; background-color: #d9d9d9; border: none; border-radius: 0;">
            
            <div class="card-header border-0 d-flex justify-content-center align-items-center" style="background-color: #1b45cf; height: 60px; border-radius: 0;">
                <h3 class="text-white mb-0" style="font-weight: 600;">ĐĂNG KÝ TÀI KHOẢN</h3>
            </div>
            
            <div class="card-body p-4">
                <form id="register" onsubmit="handleRegister(event)">
                    <div id="errorMessage" class="alert alert-danger p-2 d-none" role="alert"></div>
                    <div class="mb-4 mt-2">
                        <input id="username" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Tên đăng nhập" required>
                    </div>
                    <div class="mb-4 mt-2">
                        <input id="fullname" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Họ và tên" required>
                    </div>
                    <div class="mb-4 mt-2">
                        <input id="phone" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Số điện thoại" required>
                    </div>
                    <div class="mb-4 mt-2">
                        <input id="email" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Email" required>
                    </div>
                    <div class="mb-4 mt-2">
                        <input id="address" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Địa chỉ" required>
                    </div>
                    <div class="mb-4">
                        <input id ="password" type="password" class="form-control rounded-0 border-0 py-2" placeholder="Mật khẩu" required>
                    </div>

                    <div class="mb-4">
                        <input id="confirmPassword" type="password" class="form-control rounded-0 border-0 py-2" placeholder="Xác nhận mật khẩu" required>
                    </div>
          
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn text-white rounded-0 py-2" style="background-color: #1b45cf; font-weight: 500;">
                            Tạo tài khoản
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <span class="text-muted">Đã có tài khoản?</span>
                        <a href="/Login" style="color: #1b45cf; text-decoration: none; font-weight: 500;">Đăng nhập ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>
<script>
    function handleRegister(event) {
        event.preventDefault();

        const user = document.getElementById('username').value;
        const name = document.getElementById('fullname').value;
        const phone = document.getElementById('phone').value;
        const email = document.getElementById('email').value;
        const address = document.getElementById('address').value;

        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        const errorMess = document.getElementById('errorMessage');
        errorMess.classList.add('d-none');

        if (password !== confirmPassword) {
            errorMess.innerText = "Mật khẩu xác nhận không khớp!";
            errorMess.classList.remove('d-none');
            return;
        }

        const details = {
            Username: user,
            FullName: name,
            Phone: phone,
            Email: email,
            Address: address,
            Password: password
        };

        fetch('http://127.0.0.1:5000/auth/register', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(details)
        })
        .then(response => {
            return response.json().then(data => ({ status: response.status, body: data }));
        })
        .then(result => {
            if (result.status === 200) {
                alert('Đăng ký tài khoản thành công! Vui lòng đăng nhập.');
                window.location.replace('/Login/Index');
            } else {
                errorMess.innerText = result.body.mess || "Có lỗi xảy ra khi đăng ký.";
                errorMess.classList.remove('d-none');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            errorMess.innerText = "Không thể kết nối đến máy chủ. Vui lòng thử lại sau.";
            errorMess.classList.remove('d-none');
        });
    }
</script>