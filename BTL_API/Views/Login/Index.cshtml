@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script>
        const currentRole = localStorage.getItem('Role');

        if (currentRole) {
           
            if (currentRole === 'Customer') {
                window.location.replace('/Home/Index');
            } else {
                window.location.replace('/Admin/Product');
            }
        }
    </script>
</head>
<body style="background-color: #f4f6f9;">
    
    
    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card shadow-sm" style="width: 350px; background-color: #d9d9d9; border: none; border-radius: 0;">
            <div class="card-header border-0 d-flex justify-content-center align-items-center" style="background-color: #1b45cf; height: 60px; border-radius: 0;">
                <h4 class="text-white rounded-0" style="font-weight: 600;">Cell Tech</h4>
            </div>

            <div class="card-body p-4">
                <form id="loginForm" onsubmit="handleLogin(event)">
                    <div id="errorMessage" class="alert alert-danger p-2 d-none" role="alert"></div>

                    <div class="mb-4 mt-2">
                        <input id="username" type="text" class="form-control rounded-0 border-0 py-2" placeholder="Tên đăng nhập" required />
                    </div>
                    <div class="mb-4">
                        <input id="password" type="password" class="form-control rounded-0 border-0 py-2" placeholder="Mật khẩu" required />
                    </div>
                    <div class="d-grid mb-2">
                        <button type="submit" class="btn text-white rounded-0 py-2" style="background-color: #1b45cf; font-weight: 500;">
                            Đăng nhập
                        </button>
                    </div>
                    <div class="text-center mt-3">
                        <span class="text-muted">Chưa có tài khoản?</span>
                        <a href="/Login/Register" style="color: #1b45cf; text-decoration: none; font-weight: 500;">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function handleLogin(event) {
            event.preventDefault();

            const user = document.getElementById('username').value;
            const pwd = document.getElementById('password').value;
            const error_mess = document.getElementById('errorMessage');

            error_mess.classList.add('d-none');

            const detail = {
                Username: user,
                Password: pwd
            };

            fetch('http://127.0.0.1:5000/auth/login', {
                method: 'POST', 
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(detail)
            })
            .then(response => { 
                return response.json().then(data => ({ status: response.status, body: data }));
            })
            .then(result => {
                if (result.status === 200) {
                    localStorage.setItem('AccountID', result.body.AccountID);
                    localStorage.setItem('Role', result.body.Role);
                    alert('Đăng nhập thành công!');

                    if (result.body.Role === 'Customer') {
                       
                        window.location.href = '/Home/Index';
                    } else {
                       
                        window.location.href = '/Admin/Product';
                    }
                } else {
                   
                    error_mess.innerText = result.body.mess || "Tên đăng nhập hoặc mật khẩu không đúng.";
                    error_mess.classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                error_mess.innerText = "Không thể kết nối đến máy chủ. Vui lòng thử lại sau.";
                error_mess.classList.remove('d-none');
            });
        }
    </script>
</body>
</html>